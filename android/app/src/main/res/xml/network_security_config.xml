<?xml version="1.0" encoding="utf-8"?>
<!-- Allow plain-HTTP only to the local machine, so the app can reach the
     Firebase Emulator Suite (adb reverse tcp:9099 / tcp:8080) in debug.
     All other traffic must be HTTPS. -->
<network-security-config>
    <base-config cleartextTrafficPermitted="false" />
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">localhost</domain>
        <domain includeSubdomains="false">127.0.0.1</domain>
        <domain includeSubdomains="false">10.0.2.2</domain>
        <!-- Dev machine LAN IP for physical-device emulator testing -->
        <domain includeSubdomains="false">192.168.1.12</domain>
    </domain-config>
</network-security-config>
